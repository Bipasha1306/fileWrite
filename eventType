import java.util.*;

public class YourClass {

    private Map<String, Object> eventTypemap = new LinkedHashMap<>();

    // Original method remains unchanged
    public Map<String, Object> getFilters(Map<String, String> entityAndFilterColumn) {
        Map<String, Object> result = new LinkedHashMap<>();

        entityAndFilterColumn.forEach((key, value) -> {
            List<NotificationDetails> notificationDetailsList = notificationRepository.findAllByIsProcessedAndSourceSystemAndEntityName("N", "panda", key);
            List<String> filters = new ArrayList<>();

            notificationDetailsList.forEach(notificationDetails -> {
                try {
                    processNotificationDetails(notificationDetails, value, filters);
                } catch (JsonProcessingException e) {
                    throw new RuntimeException(e);
                }
            });

            result.put(value, filters);
        });

        return result;
    }

    // New method to retrieve eventTypeMap
    public Map<String, Object> getEventTypeMap() {
        return eventTypemap;
    }

    private void processNotificationDetails(NotificationDetails notificationDetails, String value, List<String> filters) throws JsonProcessingException {
        notificationDetails.getKeysAsMap().forEach((key2, value2) -> {
            if (value.equals(key2)) {
                eventTypemap.put(value2, notificationDetails.getEventType());
                filters.add(value2);
            }
        });
    }
}
Map<String, String> eventTypeMap = getEventTypeMap(notificationRepository, entityAndFilterColumn);

private static void writeTabSeparatedTxtToFile(String fileName, List<Map<String, String>> flatMaps, Map<String, Object> eventTypeMap) throws IOException {
    try (FileWriter writer = new FileWriter(fileName)) {
        // Write headers including the new column for eventType
        for (Map.Entry<String, String> entry : flatMaps.get(0).entrySet()) {
            writer.write(entry.getKey());
            writer.write("\t");
        }
        writer.write("eventType"); // New column header
        writer.write("\n");

        // Write values
        for (Map<String, String> flatMap : flatMaps) {
            for (Map.Entry<String, String> entry : flatMap.entrySet()) {
                writer.write(entry.getValue());
                writer.write("\t");
            }

            // Retrieve eventType based on the accountId
            String accountId = flatMap.get("accountId"); // Adjust this based on your actual key
            String eventType = eventTypeMap.get(accountId) != null ? eventTypeMap.get(accountId).toString() : "";

            writer.write(eventType); // Write eventType
            writer.write("\n");
        }
    }
}

