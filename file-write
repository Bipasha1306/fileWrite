import com.fasterxml.jackson.databind.ObjectMapper;
import com.opencsv.CSVWriter;

import java.io.FileWriter;
import java.io.IOException;
import java.util.*;

public class JsonToTabSeparatedTxtConverter {

    public static void main(String[] args) {
        String jsonString = "{\"name\": \"John\", \"age\": 30, \"address\": {\"city\": \"New York\", \"zip\": \"10001\"}, \"contacts\": [{\"type\": \"email\", \"value\": \"john@example.com\"}, {\"type\": \"phone\", \"value\": \"123456789\"}]}";

        try {
            // Step 1: Parse JSON into a Map<String, Object>
            ObjectMapper objectMapper = new ObjectMapper();
            Map<String, Object> jsonMap = objectMapper.readValue(jsonString, Map.class);

            // Step 2: Flatten the nested map
            Map<String, String> flatMap = flatten(jsonMap);

            // Step 3: Write tab-separated text data to file
            writeTabSeparatedTxtToFile("output.txt", flatMap);

            System.out.println("Tab-separated text file generated successfully.");

        } catch (IOException e) {
            e.printStackTrace();
        }
    }

    private static Map<String, String> flatten(Map<String, Object> jsonMap) {
        Map<String, String> flatMap = new LinkedHashMap<>();
        flatten("", jsonMap, flatMap);
        return flatMap;
    }

    private static void flatten(String prefix, Map<String, Object> jsonMap, Map<String, String> flatMap) {
        for (Map.Entry<String, Object> entry : jsonMap.entrySet()) {
            String key = prefix.isEmpty() ? entry.getKey() : prefix + "." + entry.getKey();
            Object value = entry.getValue();
            if (value instanceof Map) {
                flatten(key, (Map<String, Object>) value, flatMap);
            } else if (value instanceof List) {
                List<?> list = (List<?>) value;
                for (int i = 0; i < list.size(); i++) {
                    flatten(key + "[" + i + "]", (Map<String, Object>) list.get(i), flatMap);
                }
            } else {
                flatMap.put(key, value == null ? "" : value.toString());
            }
        }
    }

    private static void writeTabSeparatedTxtToFile(String fileName, Map<String, String> flatMap) throws IOException {
        try (FileWriter writer = new FileWriter(fileName)) {
            // Write headers
            for (Map.Entry<String, String> entry : flatMap.entrySet()) {
                writer.write(entry.getKey());
                writer.write("\t");
            }
            writer.write("\n");

            // Write values
            for (Map.Entry<String, String> entry : flatMap.entrySet()) {
                writer.write(entry.getValue());
                writer.write("\t");
            }
            writer.write("\n");
        }
    }
}
