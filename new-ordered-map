import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import graphql.language.*;
import org.springframework.http.ResponseEntity;

import java.io.IOException;
import java.util.*;

public class GraphQLParser {

    public static void main(String[] args) throws IOException {
        // Your GraphQL query string
        String graphqlQuery = "query accountByIds { " +
                "accountByIds(id: [129583, 23980]) { " +
                "accountId " +
                "profitabilityChannel { " +
                "code " +
                "name " +
                "} " +
                "} " +
                "}";

        // Parsing the GraphQL query to create an initial output map
        Map<String, Object> selectionSetMap = parseGraphQLQuery(graphqlQuery);
        System.out.println("Output Map from GraphQL Query:");
        printSelectionSetMap(selectionSetMap);

        // Simulating obtaining the GraphQL response through a ResponseEntity<GraphqlResponse> object
        ResponseEntity<GraphqlResponse> response = baseService.getResponse(radixQueryProperties.get().getRadixQuery(), filters);
        System.out.println("\nResponse received:");
        System.out.println(response.getBody());

        // Updating the output map with values from the GraphQL response
        updateOutputMap(selectionSetMap, response.getBody());
        System.out.println("\nUpdated Output Map after validation and inserting values from the GraphQL response:");
        printSelectionSetMap(selectionSetMap);

        // Flattening the output map
        Map<String, Object> flattenedMap = flattenMap(selectionSetMap);
        System.out.println("\nFlattened Output Map:");
        printFlattenedMap(flattenedMap);
    }

    // Method to parse the GraphQL query and create an initial output map
    private static Map<String, Object> parseGraphQLQuery(String query) {
        Map<String, Object> selectionSetMap = new LinkedHashMap<>();
        Document document = new DocumentParser().parseDocument(query);
        processSelectionSet(document.getDefinitions(), selectionSetMap);
        return selectionSetMap;
    }

    // Method to process the selection set in the GraphQL query
    private static void processSelectionSet(List<Definition> definitions, Map<String, Object> selectionSetMap) {
        for (Definition definition : definitions) {
            if (definition instanceof OperationDefinition) {
                SelectionSet selectionSet = ((OperationDefinition) definition).getSelectionSet();
                processSelectionSet(selectionSet.getSelections(), selectionSetMap);
            }
        }
    }

    private static void processSelectionSet(List<Selection> selections, Map<String, Object> selectionSetMap) {
        for (Selection selection : selections) {
            if (selection instanceof Field) {
                Field field = (Field) selection;
                String fieldName = field.getName();
                Object fieldValue;

                if (field.getSelectionSet() != null) {
                    Map<String, Object> nestedSelectionSetMap = new LinkedHashMap<>();
                    processSelectionSet(field.getSelectionSet().getSelections(), nestedSelectionSetMap);
                    fieldValue = nestedSelectionSetMap;
                } else {
                    fieldValue = null;
                }

                selectionSetMap.put(fieldName, fieldValue);
            }
        }
    }

    // Method to update the output map with values from the GraphQL response
    private static void updateOutputMap(Map<String, Object> selectionSetMap, GraphqlResponse response) {
        for (Map.Entry<String, Object> entry : selectionSetMap.entrySet()) {
            String fieldName = entry.getKey();
            Object fieldValue = getFieldValue(fieldName, response);
            entry.setValue(fieldValue);
        }
    }

    private static Object getFieldValue(String fieldName, GraphqlResponse response) {
        Map<String, Object> data = response.getData();
        if (data != null) {
            Object fieldValue = data.get(fieldName);
            if (fieldValue instanceof List) {
                List<?> fieldValues = (List<?>) fieldValue;
                List<Object> validatedFieldValues = new ArrayList<>();
                for (Object value : fieldValues) {
                    if (value instanceof Map) {
                        Map<?, ?> mapValue = (Map<?, ?>) value;
                        validatedFieldValues.add(mapValue.isEmpty() ? null : mapValue);
                    } else {
                        validatedFieldValues.add(value);
                    }
                }
                return validatedFieldValues;
            } else if (fieldValue instanceof Map) {
                Map<?, ?> mapValue = (Map<?, ?>) fieldValue;
                return mapValue.isEmpty() ? null : mapValue;
            } else {
                return fieldValue;
            }
        }
        return null;
    }

    // Method to flatten the output map
    private static Map<String, Object> flattenMap(Map<String, Object> map) {
        Map<String, Object> flattenedMap = new LinkedHashMap<>();
        flattenMap("", map, flattenedMap);
        return flattenedMap;
    }

    private static void flattenMap(String prefix, Map<String, Object> map, Map<String, Object> flattenedMap) {
        for (Map.Entry<String, Object> entry : map.entrySet()) {
            String fieldName = entry.getKey();
            Object fieldValue = entry.getValue();
            if (fieldValue instanceof Map) {
                @SuppressWarnings("unchecked")
                Map<String, Object> nestedMap = (Map<String, Object>) fieldValue;
                flattenMap(prefix + fieldName + ".", nestedMap, flattenedMap);
            } else if (fieldValue instanceof List) {
                @SuppressWarnings("unchecked")
                List<Object> listValue = (List<Object>) fieldValue;
                for (int i = 0; i < listValue.size(); i++) {
                    flattenedMap.put(prefix + fieldName + "[" + i + "]", listValue.get(i));
                }
            } else {
                flattenedMap.put(prefix + fieldName, fieldValue);
            }
        }
    }

    // Method to print the output map
    private static void printSelectionSetMap(Map<String, Object> selectionSetMap) {
        for (Map.Entry<String, Object> entry : selectionSetMap.entrySet()) {
            System.out.println(entry.getKey() + ": " + entry.getValue());
        }
    }

    // Method to print the flattened map
    private static void printFlattenedMap(Map<String, Object> flattenedMap) {
        for (Map.Entry<String, Object> entry : flattenedMap.entrySet()) {
            System.out.println(entry.getKey() + ": " + entry.getValue());
        }
    }
}
