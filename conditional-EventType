public byte[] generateTabSeparatedTxtBytes(List<Map<String, String>> flatMaps) {
    try (ByteArrayOutputStream outputStream = new ByteArrayOutputStream()) {
        // Write headers
        for (Map.Entry<String, String> entry : flatMaps.get(0).entrySet()) {
            outputStream.write(("\"" + entry.getKey() + "\"\t").getBytes());
        }
        outputStream.write("\"eventType\"\n".getBytes()); // Add the eventType header

        // Write values
        for (Map<String, String> flatMap : flatMaps) {
            String accountIdColumnName = getAccountIdColumnName(); // Retrieve the dynamic column name for accountId
            String eventType = eventTypemap.get(flatMap.get(accountIdColumnName)); // Get eventType based on the dynamic column
            if ("DELETE".equals(eventType)) {
                // For DELETE event type, only write accountId and eventType
                outputStream.write(("\"" + flatMap.get(accountIdColumnName) + "\"\t").getBytes());
                outputStream.write(("\"" + eventType + "\"\n").getBytes());
            } else {
                // For other event types, write all columns
                for (Map.Entry<String, String> entry : flatMap.entrySet()) {
                    outputStream.write(("\"" + entry.getValue() + "\"\t").getBytes());
                }
                outputStream.write(("\"" + eventType + "\"\n").getBytes());
            }
        }

        System.out.println("Tab-separated text file generated successfully.");
        return outputStream.toByteArray();
    } catch (IOException e) {
        e.printStackTrace();
        // Handle exception appropriately, e.g., return an error response
        return new byte[]{};
    }
}

