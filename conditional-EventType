public byte[] generateTabSeparatedTxtBytes(List<Map<String, String>> flatMaps) {
    try (ByteArrayOutputStream outputStream = new ByteArrayOutputStream()) {
        // Write headers
        for (Map.Entry<String, String> entry : flatMaps.get(0).entrySet()) {
            outputStream.write(("\"" + entry.getKey() + "\"\t").getBytes());
        }
        outputStream.write("\"eventType\"\t".getBytes()); // New column header for eventType
        outputStream.write("\n".getBytes());

        // Write values
        for (Map<String, String> flatMap : flatMaps) {
            String accountId = flatMap.get("accountId"); // Adjust this based on your actual key
            String eventType = eventTypemap.get(accountId) != null ? eventTypemap.get(accountId) : "";

            // Write accountId
            outputStream.write(("\"" + accountId + "\"\t").getBytes());

            // Conditionally handle eventType
            if ("DELETE".equals(eventType)) {
                outputStream.write(("\"" + eventType + "\"\t").getBytes()); // Write eventType for DELETE
            } else {
                // For other event types, leave other columns empty
                for (int i = 1; i < flatMap.size(); i++) {
                    outputStream.write("\"\"\t".getBytes());
                }
            }

            outputStream.write("\n".getBytes());
        }

        log.info("Tab-separated text file generated successfully.");
        return outputStream.toByteArray();
    } catch (IOException e) {
        e.printStackTrace();
        // Handle exception appropriately, e.g., return an error response
        return new byte[]{};
    }
}
