 Map<String, List<String>> selectionSetMap = parseGraphQLQuery(graphqlQuery);
        printSelectionSetMap(selectionSetMap);
    }

    private static Map<String, List<String>> parseGraphQLQuery(String query) {
        Map<String, List<String>> selectionSetMap = new LinkedHashMap<>();
        Document document = new io.altoviso.core.graphql.parser.Parser().parseDocument(query);

        for (Definition definition : document.getDefinitions()) {
            if (definition instanceof OperationDefinition) {
                SelectionSet selectionSet = ((OperationDefinition) definition).getSelectionSet();
                processSelectionSet(selectionSet, selectionSetMap);
            }
        }

        return selectionSetMap;
    }

    private static void processSelectionSet(SelectionSet selectionSet, Map<String, List<String>> selectionSetMap) {
        for (Selection selection : selectionSet.getSelections()) {
            if (selection instanceof Field) {
                Field field = (Field) selection;
                String fieldName = field.getName();
                List<String> subfields = new ArrayList<>();

                if (field.getSelectionSet() != null) {
                    processSelectionSet(field.getSelectionSet(), selectionSetMap);
                    subfields.addAll(selectionSetMap.get(fieldName));
                }

                selectionSetMap.put(fieldName, subfields);
            }
        }
    }

    private static void printSelectionSetMap(Map<String, List<String>> selectionSetMap) {
        for (Map.Entry<String, List<String>> entry : selectionSetMap.entrySet()) {
            System.out.println(entry.getKey() + ": " + entry.getValue());
        }
    }
}
